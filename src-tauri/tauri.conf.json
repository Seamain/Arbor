{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arbor",
  "version": "0.1.0",
  "identifier": "com.seamainzhang.arbor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Arbor",
        "width": 1280,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 600,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https: http://127.0.0.1:*; font-src 'self' data:; worker-src 'self' blob:"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdBNTU3MTdEMDdGQkE5M0EKUldRNnFmc0hmWEZWZWtEMXhyUU5hekFRTEVpZjlhTDRhaTVqZ2M0MFV4ek51RGFkM0thcTU3MUUK",
      "endpoints": [
        "https://github.com/seamainzhang/arbor/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "windows": {
      "wix": {
        "fragmentPaths": ["wix/create-folder.wxs"],
        "componentRefs": ["CreateInstallDir"],
        "featureGroupRefs": [],
        "featureRefs": ["CreateDirFeature"],
        "mergeRefs": []
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "SimpChinese"],
        "displayLanguageSelector": true
      }
    }
  }
}
